{
  "name": "validar-dni",
  "version": "1.0.0",
  "description": "Lightweight TypeScript library to validate Spanish DNI, NIE and CIF identifiers",
  "keywords": ["dni", "nie", "cif", "nif", "spain", "validate", "spanish", "identifier"],
  "author": "Pol Gubau Amores",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PolGubau/validar-dni"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}

